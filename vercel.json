{
  "$schema": "https://openapi.vercel.sh/vercel.json",

  "services": {
    "frontend": {
      "root": ".",
      "installCommand": "npm ci",
      "buildCommand": "npm run build",
      "outputDirectory": "static",
      "framework": "vite"
    },
    "backend": {
      "root": ".",
      "installCommand": "uv sync --extra pg-binary",
      "entrypoint": "project/wsgi.py",
      "framework": "django"
    }
  },

  "rewrites": [
    {
      "source": "/(.*)",
      "destination": {
        "service": "backend"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "frontend"
      }
    }
  ]
}